    <script>
        // Theme Management
        const themeToggle = document.getElementById('themeToggle');
        const body = document.body;
        const icon = themeToggle.querySelector('i');

        // Check for saved theme
        const savedTheme = localStorage.getItem('waslatech-theme');
        if (savedTheme === 'dark') {
            body.classList.add('dark-mode');
            icon.classList.replace('fa-moon', 'fa-sun');
        }

        themeToggle.addEventListener('click', () => {
            body.classList.toggle('dark-mode');
            const isDark = body.classList.contains('dark-mode');
            localStorage.setItem('waslatech-theme', isDark ? 'dark' : 'light');
            
            if (isDark) {
                icon.classList.replace('fa-moon', 'fa-sun');
            } else {
                icon.classList.replace('fa-sun', 'fa-moon');
            }
        });

        // Mobile Menu
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const navLinks = document.querySelector('.nav-links');
        
        mobileMenuBtn.addEventListener('click', () => {
            navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
            navLinks.style.flexDirection = 'column';
            navLinks.style.position = 'absolute';
            navLinks.style.top = '5rem';
            navLinks.style.left = '0';
            navLinks.style.width = '100%';
            navLinks.style.background = 'var(--bg-light)';
            navLinks.style.padding = '2rem';
            navLinks.style.borderBottom = '1px solid var(--border)';
        });

        // Auth Tabs
        function switchAuthTab(tab) {
            const loginCard = document.getElementById('loginCard');
            const signupCard = document.getElementById('signupCard');
            const loginBtn = document.getElementById('tabLoginBtn');
            const signupBtn = document.getElementById('tabSignupBtn');

            if (tab === 'login') {
                loginCard.classList.remove('hidden');
                signupCard.classList.add('hidden');
                loginBtn.classList.add('active');
                signupBtn.classList.remove('active');
            } else {
                loginCard.classList.add('hidden');
                signupCard.classList.remove('hidden');
                loginBtn.classList.remove('active');
                signupBtn.classList.add('active');
            }
        }

        // Form Validation Helpers
        function showError(id, message) {
            const el = document.getElementById(id);
            if (el) {
                el.textContent = message;
                el.style.display = 'block';
            }
        }

        function clearErrors() {
            document.querySelectorAll('.error-message').forEach(el => {
                el.textContent = '';
                el.style.display = 'none';
            });
        }

        // Contact Form
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            clearErrors();
            
            const name = document.getElementById('cName').value.trim();
            const email = document.getElementById('cEmail').value.trim();
            const msg = document.getElementById('cMessage').value.trim();
            let valid = true;

            if (name.length < 2) { showError('nameError', 'Name is too short'); valid = false; }
            if (!email.includes('@')) { showError('emailError', 'Invalid email address'); valid = false; }
            if (msg.length < 10) { showError('messageError', 'Message must be at least 10 characters'); valid = false; }

            if (valid) {
                alert('✅ Thank you! Your message has been sent successfully.');
                this.reset();
            }
        });

        // Login Form
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            clearErrors();
            const email = document.getElementById('loginEmail').value.trim();
            const pass = document.getElementById('loginPassword').value;
            
            if (!email.includes('@')) { showError('loginEmailError', 'Invalid email'); return; }
            if (pass.length < 6) { showError('loginPasswordError', 'Password too short'); return; }
            
            alert('✅ Login successful!');
            this.reset();
        });

        // Signup Form
        document.getElementById('signupForm').addEventListener('submit', function(e) {
            e.preventDefault();
            clearErrors();
            const name = document.getElementById('signupName').value.trim();
            const email = document.getElementById('signupEmail').value.trim();
            const pass = document.getElementById('signupPassword').value;
            const confirm = document.getElementById('confirmPassword').value;
            
            if (name.length < 2) { showError('signupNameError', 'Name is too short'); return; }
            if (!email.includes('@')) { showError('signupEmailError', 'Invalid email'); return; }
            if (pass.length < 6) { showError('signupPasswordError', 'Password must be at least 6 characters'); return; }
            if (pass !== confirm) { showError('confirmPasswordError', 'Passwords do not match'); return; }
            
            alert('🎉 Account created successfully!');
            this.reset();
            switchAuthTab('login');
        });

        // Pricing Plan Selection
        function selectPlan(name, price) {
            alert(`Selected Plan: ${name} (${price})\nRedirecting to contact form...`);
            document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
        }

        // Chatbot Logic
        function toggleChat() {
            const window = document.getElementById('chatWindow');
            window.style.display = window.style.display === 'flex' ? 'none' : 'flex';
        }

        function sendMessage() {
            const input = document.getElementById('chatInput');
            const body = document.getElementById('chatBody');
            const msg = input.value.trim();
            
            if (!msg) return;

            // Add user message
            const userMsg = document.createElement('div');
            userMsg.className = 'message user';
            userMsg.textContent = msg;
            body.appendChild(userMsg);
            input.value = '';
            body.scrollTop = body.scrollHeight;

            // Bot reply
            setTimeout(() => {
                const botMsg = document.createElement('div');
                botMsg.className = 'message bot';
                
                const lowerMsg = msg.toLowerCase();
                if (lowerMsg.includes('price') || lowerMsg.includes('plan')) {
                    botMsg.textContent = "Our plans start at $99/month for Small Business. We also offer Enterprise custom pricing.";
                } else if (lowerMsg.includes('contact') || lowerMsg.includes('support')) {
                    botMsg.textContent = "You can reach us at +966 1 234 5678 or use the contact form on this page.";
                } else if (lowerMsg.includes(' features ') || lowerMsg.includes(' services ')) {
                    botMsg.textContent = "We provide you different plans, Enterprise Security, High-speed network, Dedicated Support, Global Connectivity, Cloud Integration, and Flexible Pricing.";
                } else {
                    botMsg.textContent = "Thanks for your message! One of our experts will get back to you soon.";
                }
                
                body.appendChild(botMsg);
                body.scrollTop = body.scrollHeight;
            }, 800);
        }

        // Handle Enter key for chat
        document.getElementById('chatInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // Smooth scrolling for all nav links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });
    </script>
